<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state (D-pad hovering) - Bento theme -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#3B82F6" /> <!-- Blue-500 -->
            <corners android:radius="14dp" />
            <stroke android:width="2dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Selected state (Currently active category) - Bento theme -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#2563EB" /> <!-- Blue-600 -->
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#60A5FA" />
        </shape>
    </item>
    <!-- Default state - Bento slate-800 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1E293B" /> <!-- Translucent Slate 800 -->
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#15334155" /> <!-- Translucent Slate 700 -->
        </shape>
    </item>
</selector>
