<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused card state (D-pad hovering) - Bento blue-gradient theme -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient 
                android:startColor="#3B82F6" 
                android:endColor="#1D4ED8" 
                android:angle="315" />
            <corners android:radius="20dp" />
            <stroke android:width="2.5dp" android:color="#A0FFFFFF" /> <!-- Elegant semi-translucent white border -->
        </shape>
    </item>
    <!-- Default card state - Sleek slate bento tile -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1E293B" /> <!-- Translucent Slate 800/50 -->
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#20334155" /> <!-- Slate 700/30 -->
        </shape>
    </item>
</selector>
